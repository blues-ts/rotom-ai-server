# Core
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/rotom-ai

# Redis
REDIS_HOST=disabled
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication (Clerk)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Google Gemini AI
GOOGLE_GENAI_API_KEY=

# Poketrace API
POKETRACE_API_KEYS=
POKETRACE_BASE_URL=https://api.poketrace.com/v1
POKETRACE_BURST_LIMIT=30
POKETRACE_BURST_WINDOW_MS=10000

# Caching
CACHE_TTL=86400
CACHE_MAX_SIZE=10000

# Logging
LOG_LEVEL=info
